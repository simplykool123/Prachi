# Supabase (required — already configured)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google Calendar Sync (optional — needed to sync appointments to Google Calendar / mobile)
#
# Steps to set up:
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project (or use existing)
# 3. Enable "Google Calendar API" under APIs & Services
# 4. Go to APIs & Services > Credentials > Create OAuth 2.0 Client ID
# 5. Application type: Web application
# 6. Add your app URL to "Authorized JavaScript origins" (e.g. http://localhost:5173)
# 7. Copy the Client ID below
# 8. Create a .env file in the project root and paste it in
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
